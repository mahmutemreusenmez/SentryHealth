NODE_ENV=development
PORT=3000

# HMAC key used to pseudonymize patient identifiers. Must be at least 16 chars.
# Generate a strong random value, e.g.: openssl rand -base64 48
ANONYMIZATION_KEY=change-me-to-a-strong-random-32-byte-secret

# Bootstrap admin account. ADMIN_PASSWORD must be at least 8 chars.
ADMIN_USERNAME=yönetici
ADMIN_PASSWORD=change-me-strong-admin-password
ADMIN_DISPLAY_NAME=Sistem Yöneticisi

# Comma-separated list of allowed browser origins for CORS.
# Leave empty to disallow cross-origin browser requests (same-origin only).
# Example: CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=

LOG_LEVEL=info
