{
  "expo": {
    "name": "SentryCompanion AI",
    "slug": "sentry-companion-ai",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "sentrycompanion",
    "newArchEnabled": false,
    "splash": {
      "backgroundColor": "#0a7c86"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "tr.gov.saglik.sentrycompanion",
      "infoPlist": {
        "NSCameraUsageDescription": "Canlı görüntülü triyaj görüşmesi için kameranıza erişim gerekir.",
        "NSMicrophoneUsageDescription": "Canlı görüntülü triyaj görüşmesi için mikrofonunuza erişim gerekir."
      }
    },
    "android": {
      "package": "tr.gov.saglik.sentrycompanion",
      "adaptiveIcon": {
        "backgroundColor": "#0a7c86"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#0a7c86"
        }
      ],
      "expo-secure-store"
    ]
  }
}
