# SentryCompanion AI — LLM API yapılandırması (opsiyonel)
#
# Bu değişkenler tanımlı DEĞİLSE uygulama otomatik olarak "Çevrimdışı Mod"da
# çalışır ve yerel şifreli şablonlardan acil durum önerileri üretir.
#
# GERÇEK anahtarı bu dosyaya YAZMAYIN ve commit ETMEYIN. Yerel `.env` dosyanıza
# kopyalayın (git tarafından yok sayılır) veya CI/EAS secret olarak sağlayın.
#
# Prodüksiyon için önerilen: doğrudan sağlayıcı anahtarı yerine kendi backend
# proxy endpoint'inizi verin; böylece gizli anahtar sunucu tarafında kalır.

# OpenAI uyumlu sohbet tamamlama endpoint kökü
EXPO_PUBLIC_AI_BASE_URL=https://api.openai.com/v1

# Model adı
EXPO_PUBLIC_AI_MODEL=gpt-4o-mini

# API anahtarı (yalnızca demo/geliştirme; prodüksiyonda backend proxy kullanın)
EXPO_PUBLIC_AI_API_KEY=

# --- Canlı Görüntülü Triyaj (WebRTC sinyalleşme) ---
#
# "Görüşmeyi Başlat" ve "Ebe/Hemşireye Bağlan" butonları, SentryHealth web
# sitesindeki WebSocket sinyal sunucusuna (/rtc) bağlanır. Tanımlı değilse yerel
# geliştirme sunucusu (ws://localhost:3000/rtc) kullanılır.
#
# WebSocket sinyal adresi (ör. wss://sentryhealth.example.com/rtc)
EXPO_PUBLIC_SIGNAL_URL=ws://localhost:3000/rtc

# Web sitesi HTTP kökü (native WebView görüşme sayfası için; verilmezse yukarıdan türetilir)
EXPO_PUBLIC_SIGNAL_HTTP=http://localhost:3000
